generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
}

enum TruckStatus {
  ACTIVE
  UNDER_REPAIR
  INACTIVE
}

enum PersonStatus {
  ACTIVE
  INACTIVE
}

enum BookingStatus {
  DRAFT
  QUOTED
  CONFIRMED
  DISPATCHED
  COMPLETED
  CANCELLED
}

enum VatOption {
  VAT_INCLUSIVE
  VAT_EXCLUSIVE
  NON_VAT
}

enum ServiceType {
  LIPAT_BAHAY
  COMMERCIAL_DELIVERY
  CATERING_DELIVERY
  OTHER
}

enum BillingType {
  EIGHT_HOUR
  PER_TRIP
}

enum ClientType {
  INDIVIDUAL_PERSON
  INDIVIDUAL_BUSINESS
  CORPORATION_BUSINESS
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  fullName     String
  role         UserRole @default(ADMIN)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  quotesCreated   Quote[]   @relation("QuoteCreator")
  bookingsCreated Booking[] @relation("BookingCreator")
}

model TruckType {
  id        String @id @default(cuid())
  code      String @unique // "10FT_4W", "14FT_6W", "16FT_DROPSIDE", etc.
  label     String // "10 ftr - 4 wheels"
  sizeFt    Int
  wheelType String // "4-wheel" | "6-wheel"

  // Per-billing-type base rate (set in Pricing Config UI per truck type)
  eightHourBaseRate Decimal @db.Decimal(12, 2) // base for EIGHT_HOUR billing
  perTripBaseRate   Decimal @db.Decimal(12, 2) // base for PER_TRIP billing

  // Retained operational metadata (informational, not consumed by pricing engine)
  dailyRate      Decimal @db.Decimal(12, 2)
  excessHourRate Decimal @db.Decimal(12, 2)

  trucks Truck[]
}

model Truck {
  id          String      @id @default(cuid())
  code        String      @unique // "V5", "V6", "ELF1"
  plateNo     String      @unique
  truckTypeId String
  truckType   TruckType   @relation(fields: [truckTypeId], references: [id])
  status      TruckStatus @default(ACTIVE)
  remarks     String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  bookings Booking[]
}

model Driver {
  id         String       @id @default(cuid())
  employeeId String       @unique // e.g. "2013030"
  fullName   String
  dailyRate  Decimal      @db.Decimal(12, 2)
  otRate     Decimal      @db.Decimal(12, 2)
  status     PersonStatus @default(ACTIVE)
  remarks    String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  bookings Booking[]
}

model Helper {
  id         String       @id @default(cuid())
  employeeId String       @unique
  fullName   String
  dailyRate  Decimal      @db.Decimal(12, 2)
  otRate     Decimal      @db.Decimal(12, 2)
  status     PersonStatus @default(ACTIVE)
  remarks    String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  bookingHelpers BookingHelper[]
}

model Client {
  id            String     @id @default(cuid())
  clientCode    String?    @unique
  clientName    String
  type          ClientType @default(INDIVIDUAL_BUSINESS)
  contactPerson String?
  mobile        String?
  landline      String?
  email         String?
  tin           String?
  address       String?            @db.Text
  notes         String?
  isActive      Boolean            @default(true)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  quotes   Quote[]
  bookings Booking[]
}

model RouteArea {
  id             String  @id @default(cuid())
  code           String  @unique // "METRO_MANILA", "CENTRAL_LUZON"
  label          String
  sampleDest     String? @db.Text
  distanceMinKm  Int
  distanceMaxKm  Int
  surcharge      Decimal @db.Decimal(12, 2)
  estimatedToll  Decimal @db.Decimal(12, 2)
  isLongDistance Boolean @default(false)
  remarks        String?
}

// SINGLETON: only one row, id = 1. Pricing Config (post-refactor bottom-up engine).
model RateSettings {
  id Int @id @default(1)

  // LABOR MARKUPS — percentages of Revenue Net of VAT
  driverRate Decimal @db.Decimal(5, 4) // 0.1500 = 15%
  helperRate Decimal @db.Decimal(5, 4) // 0.0750 = 7.5%

  // OVERHEAD & SURCHARGES — percentages of Revenue Net of VAT
  overheadRate            Decimal @db.Decimal(5, 4) // 0.0500
  longDistanceRate        Decimal @db.Decimal(5, 4) // 0.0500
  longDistanceThresholdKm Int // 50

  // FUEL CONFIG
  dieselPricePerLiter Decimal @db.Decimal(8, 2) // 70.00 (current diesel price)
  fuelFloor           Decimal @db.Decimal(12, 2) // 500 (minimum fuel charge)
  fuelEfficiencyKmpl  Decimal @db.Decimal(5, 2) // 5.00 (km per liter, global)

  // ADD-ON RATES — added to direct costs (other_direct_costs)
  additionalHelperRate    Decimal @db.Decimal(12, 2) // 600 (when additionalHelper flag set)
  additionalHourRate      Decimal @db.Decimal(12, 2) // 350 (per excess hour beyond standard)
  additionalDropoffCharge Decimal @db.Decimal(12, 2) // 300 (per extra drop-off)
  standardIncludedHours   Int // 8

  // SPECIAL SERVICE FEES — added to direct costs when corresponding flag is set
  condoHandlingFee    Decimal @db.Decimal(12, 2) // 500
  cateringHandlingFee Decimal @db.Decimal(12, 2) // 400
  loadingUnloadingFee Decimal @db.Decimal(12, 2) // 0

  // DISTANCE
  distanceRatePerKm Decimal @db.Decimal(12, 2) // 12

  // TAX (locked, regulated by BIR)
  vatRate Decimal @db.Decimal(5, 4) // 0.1200

  updatedAt DateTime @updatedAt
  updatedBy String?
}

// SINGLETON: only one row, id = 1. Payment method details shown on PDF quotations.
model PaymentConfig {
  id           Int      @id @default(1)
  bank1Name    String   @default("EASTWEST BANK")
  bank1Holder  String   @default("JOLEO TRANSPORT")
  bank1Account String   @default("200048853462")
  bank2Name    String   @default("BDO UNIBANK")
  bank2Holder  String   @default("JOLEO TRANSPORT")
  bank2Account String   @default("013208001304")
  gcashHolder  String   @default("LEOVINA SALVADOR")
  gcashNumber  String   @default("09178305652")
  updatedAt    DateTime @updatedAt
}

model Quote {
  id       String   @id @default(cuid())
  quoteNo  String   @unique // "QT-20260519-0001"
  status   String   @default("DRAFT") // DRAFT | SENT | ACCEPTED | REJECTED | EXPIRED
  quotedAt DateTime @default(now())

  clientId    String?
  client      Client? @relation(fields: [clientId], references: [id])
  walkInName  String? // when no client record

  serviceType         ServiceType @default(LIPAT_BAHAY)
  pickupPoint         String
  dropoffPoint        String
  routeAreaId         String?
  estimatedDistanceKm Int
  estimatedHours      Int?
  numberOfDropoffs    Int         @default(1)

  // Truck/crew (suggested at quote time, finalized at booking)
  truckTypeId     String?
  numberOfHelpers Int     @default(1)

  // Billing type — chosen at quote time, determines which truck-type base rate applies
  tripBillingType BillingType @default(EIGHT_HOUR)

  // Flags
  condoService     Boolean @default(false)
  cateringService  Boolean @default(false)
  additionalHelper Boolean @default(false)

  // Costs
  tollFee           Decimal  @db.Decimal(12, 2) @default(0) // pass-through, no markup
  fuelPriceOverride Decimal? @db.Decimal(8, 2) // override current diesel price for this quote only
  discountAmount    Decimal  @db.Decimal(12, 2) @default(0)
  vatOption         VatOption @default(VAT_INCLUSIVE)

  // Snapshot of pricing engine output at the moment of quote
  pricingSnapshot     Json // full PricingResult, includes rateSettings used
  finalPrice          Decimal  @db.Decimal(12, 2)
  manualOverridePrice Decimal? @db.Decimal(12, 2)

  serviceDescription String? @db.Text
  notes              String? @db.Text
  paymentTerms       String? @db.Text

  // Schedule — when the move will happen. Date is captured at quote time, time is optional.
  scheduledDate      DateTime? @db.Date
  scheduledStartTime String?   // "HH:MM" 24-hour, e.g. "07:00"

  createdById String
  createdBy   User     @relation("QuoteCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  booking Booking?
}

model Booking {
  id        String        @id @default(cuid())
  bookingNo String        @unique // "JOL-20260519-0001"
  status    BookingStatus @default(DRAFT)

  quoteId String? @unique
  quote   Quote?  @relation(fields: [quoteId], references: [id])

  clientId   String?
  client     Client? @relation(fields: [clientId], references: [id])
  walkInName String?

  // Schedule
  scheduledDate      DateTime @db.Date
  scheduledStartTime String? // "06:30"
  scheduledEndTime   String? // "18:00"
  actualStartAt      DateTime?
  actualEndAt        DateTime?

  // Trip details
  pickupPoint         String
  dropoffPoint        String
  estimatedDistanceKm Int
  routeAreaId         String?
  tripBillingType     BillingType @default(EIGHT_HOUR)

  // Assignment
  truckId  String?
  truck    Truck?  @relation(fields: [truckId], references: [id])
  driverId String?
  driver   Driver? @relation(fields: [driverId], references: [id])
  helpers  BookingHelper[]

  // Financial
  quotedAmount Decimal  @db.Decimal(12, 2)
  finalAmount  Decimal? @db.Decimal(12, 2)

  notes        String? @db.Text
  cancelReason String?

  createdById String
  createdBy   User     @relation("BookingCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([scheduledDate])
  @@index([truckId, scheduledDate])
  @@index([status])
}

model BookingHelper {
  bookingId String
  helperId  String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  helper    Helper  @relation(fields: [helperId], references: [id])

  @@id([bookingId, helperId])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String // "RATE_SETTINGS_UPDATED", "BOOKING_CANCELLED", etc.
  entityType String?
  entityId   String?
  before     Json?
  after      Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}
